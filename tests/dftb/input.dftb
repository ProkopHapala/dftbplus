Geometry = xyzFormat {
  <<< "h2o.xyz"
}

ParserOptions {
  ParserVersion = 15
}

Hamiltonian = DFTB {
  Scc = Yes
  MaxAngularMomentum {
    O = "p"
    H = "s"
